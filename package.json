{
  "name": "llm-scripts",
  "description": "Portable scripts for LLM workflows. Clone into any repo and run from your project root.",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "merge":     "node run.js merge",
    "merge-git": "node run.js merge-git",
    "optimize":  "node run.js optimize",
    "collect-serp": "node run.js collect-serp",
    "test:serp": "node --test serp-helpers/__tests__/*.test.mjs"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "sharp": "^0.34.0"
  }
}
